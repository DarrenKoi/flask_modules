# Copy to .env before `docker compose up`.
# AIRFLOW_UID lets the container write to mounted volumes as your user.
# On Windows/WSL, 50000 is a safe default that matches the official image.
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.

# Optional admin credentials (defaults to airflow/airflow)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
